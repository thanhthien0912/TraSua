=== Order model ===
model Order {
  id          Int         @id @default(autoincrement())
  tableId     Int
  table       Table       @relation(fields: [tableId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Int         @default(0)
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@map("orders")
}
