=== Table Model ===
model Table {
  id     Int     @id @default(autoincrement())
  number Int     @unique
  name   String  // e.g. "Bàn 1"
  orders Order[]

  @@map("tables")
}

=== Order Model ===
model Order {
  id          Int         @id @default(autoincrement())
  tableId     Int
  table       Table       @relation(fields: [tableId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Int         @default(0)
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@map("orders")
}

