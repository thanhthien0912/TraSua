=== Table Model ===
model Table {
  id     Int     @id @default(autoincrement())
  number Int     @unique
  name   String  // e.g. "Bàn 1"
  orders Order[]

  @@map("tables")
}

=== Order Model ===
model Order {
  id          Int         @id @default(autoincrement())
  tableId     Int
  table       Table       @relation(fields: [tableId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Int         @default(0)
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@map("orders")
}

=== Admin Tables Stub ===
export default function AdminTablesPage() {
  return (
    <main className="px-4 py-6">
      <h1
        className="text-xl font-bold tracking-tight"
        style={{ color: '#78350f' }}
      >
        🪑 Quản lý bàn
      </h1>
      <p className="mt-2 text-sm" style={{ color: '#92400e', opacity: 0.7 }}>
        Trang quản lý bàn sẽ được hoàn thiện ở bước tiếp theo.
      </p>
    </main>
  )
}


