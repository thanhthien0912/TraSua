=== MENU PICKER MODAL (form pattern) ===
'use client'

import { useState, useEffect, useCallback, useRef } from 'react'
import { formatVND } from '@/lib/format'

// ─── Types ──────────────────────────────────────────────────────────

interface MenuItem {
  id: number
  name: string
  price: number
  category: 'DRINK' | 'FOOD'
  available: boolean
  sortOrder: number
}

type Tab = 'DRINK' | 'FOOD'

const TABS: { key: Tab; label: string }[] = [
  { key: 'DRINK', label: 'Đồ uống' },
  { key: 'FOOD', label: 'Đồ ăn' },
]

// ─── Props ──────────────────────────────────────────────────────────

interface MenuPickerModalProps {
  orderId: number
  tableId: number
  isOpen: boolean
  onClose: () => void
  onSuccess: () => void
}

// ─── MenuPickerModal ────────────────────────────────────────────────

